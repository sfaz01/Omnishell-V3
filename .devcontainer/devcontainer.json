{
  "name": "OmniShell Dev",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.11-bookworm",
  "customizations": {
    "codespaces": {
      "openFiles": [
        "README.md",
        "omnishell/cli.py"
      ]
    },
    "vscode": {
      "settings": {},
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance"
      ]
    }
  },
  "updateContentCommand": "pip3 install --user -e '.[all]' && echo '✅ OmniShell installed'",
  "postAttachCommand": {
    "server": "streamlit run omnishell/web.py --server.enableCORS false --server.enableXsrfProtection false"
  },
  "portsAttributes": {
    "8501": {
      "label": "OmniShell Web",
      "onAutoForward": "openPreview"
    }
  },
  "forwardPorts": [
    8501
  ]
}